# Example Caddy reverse proxy for linux-central-management
#
# Supports both modes:
# - Domain/TLS mode:   FLEET_SITE_ADDR=fleet.example.com
# - IP/no-domain mode: FLEET_SITE_ADDR=:80  (or 192.168.1.10:80)
#
# Notes:
# - Caddy enables HTTPS automatically for hostnames (domain mode).
# - For plain HTTP/IP mode, include an explicit :80 listener.
# - Upstream should usually be server:8000 when Caddy and app share Docker network.

{$FLEET_SITE_ADDR::80} {
  encode zstd gzip

  # Reverse proxy to the app
  reverse_proxy {$FLEET_UPSTREAM:server:8000} {
    # Propagate client/proto information to the app
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Real-IP {remote_host}
  }

  # Basic security headers (app also sets some)
  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "same-origin"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
    X-Frame-Options "DENY"
  }

  # NOTE: `rate_limit` is not part of stock Caddy images.
  # Keep this file compatible with `caddy:2` out of the box.
  # If you need edge rate limiting, either:
  #   - use a Caddy build with a rate-limit plugin, or
  #   - apply limits at your LB/WAF (Cloudflare, nginx, Traefik, etc).
}
