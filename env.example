# Same as .env.example, but without a leading dot (some systems hide dotfiles).
# Copy to .env

# Used by script.sh to start local agent (optional)
# For local development/testing you can use a simple shared token.
AGENT_TOKEN=change-me-agent-token
# Terminal token (agent-side). script.sh reads TERM_TOKEN and exports it as FLEET_TERMINAL_TOKEN.
TERM_TOKEN=
# Terminal listener defaults to 127.0.0.1:18080. Expose only on a management interface when needed.
# TERM_LISTEN=127.0.0.1:18080
# Terminal login backend for deployed agents: auto, ssh, or login.
# auto uses SSH when local SSH is reachable, otherwise falls back to agetty/login.
TERM_BACKEND=auto
